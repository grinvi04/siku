{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "team-harness 기반 — 공통 가드·시크릿 유출 탐지·git-flow 커맨드는 harness-guard 플러그인이 제공. 아래 hooks는 siku 고유분만 (플러그인 훅과 공존).",
  "permissions": {
    "allow": [
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(gh repo view *)"
    ],
    "deny": [],
    "disableBypassPermissionsMode": "disable"
  },
  "extraKnownMarketplaces": {
    "team-harness": {
      "source": {
        "source": "github",
        "repo": "grinvi04/team-harness"
      }
    }
  },
  "enabledPlugins": {
    "harness-guard@team-harness": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-dangerous.sh",
            "timeout": 10,
            "statusMessage": "siku 가드 검사 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/validate-edit.sh",
            "timeout": 120,
            "statusMessage": "코드 검증 중 (lint · 테스트)..."
          }
        ]
      }
    ]
  }
}
