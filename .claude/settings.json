{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(gh repo view *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(openssl rand *)",
      "Skill(update-config)",
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npm ci *)",
      "Bash(npm test *)",
      "Bash(npm ls *)",
      "Bash(npm -v)",
      "Bash(npx jest *)",
      "Bash(npx tsc *)",
      "Bash(npx prettier *)",
      "Bash(npx eslint *)",
      "Bash(npx playwright *)",
      "Bash(node *)",
      "Bash(docker-compose *)",
      "Bash(docker compose *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(ssh *)",
      "Bash(curl * | bash *)",
      "Bash(wget * | bash *)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-dangerous.sh",
            "timeout": 10,
            "statusMessage": "siku 가드 검사 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PROJECT_DIR}/.claude/hooks/validate-edit.sh",
            "timeout": 120,
            "statusMessage": "코드 검증 중 (lint · 테스트)..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "harness-guard@team-harness": true,
    "frontend-design@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "team-harness": {
      "source": {
        "source": "github",
        "repo": "grinvi04/team-harness"
      }
    }
  },
  "_comment": "team-harness 기반 — 공통 가드·시크릿 유출 탐지·git-flow 커맨드는 harness-guard 플러그인이 제공. 아래 hooks는 siku 고유분만 (플러그인 훅과 공존)."
}
